{
  "expo": {
    "name": "Kingdomino Pointberegner",
    "slug": "kingdomino-pointberegner",
    "version": "1.0.0",
    "orientation": "portrait",
    "splash": {
      "image": "./assets/hero.png",
      "resizeMode": "cover",
      "backgroundColor": "#111111"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Giv appen adgang til kameraet for at scanne Kingdomino pladen."
        }
      ]
    ],
    "android": {
      "permissions": [
        "CAMERA"
      ],
      "package": "com.kingdomino.pointberegner"
    },
    "ios": {
      "infoPlist": {
        "NSCameraUsageDescription": "Appen bruger kameraet til at scanne Kingdomino plader."
      },
      "bundleIdentifier": "com.kingdomino.pointberegner"
    }
  }
}
