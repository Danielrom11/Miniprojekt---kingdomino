import cv2
import numpy as np

# 1. SETUP
main_path = r"C:\Users\danie\Desktop\2. semester\Miniprojekt - kingdomino\Trainingset\7.jpg"
template_paths = [
    r"C:\Users\danie\Desktop\2. semester\Miniprojekt - kingdomino\features\kongekrone_nord.jpg",
    r"C:\Users\danie\Desktop\2. semester\Miniprojekt - kingdomino\features\kongekrone_syd.png"
]

img_bgr = cv2.imread(main_path)
if img_bgr is None: raise FileNotFoundError("Image not found")
search_image = cv2.split(img_bgr)[0] 

all_found_rects = []
# ADJUST THIS: If it still finds too few, lower to 0.60. If it finds "fake" crowns, raise to 0.70
detection_threshold = 0.70

print("Scanning for all crowns...")

# 2. THE SEARCH
for t_path in template_paths:
    original_template = cv2.imread(t_path, cv2.IMREAD_GRAYSCALE)
    if original_template is None: continue

    # Using 50 steps for better size matching
    for scale in np.linspace(1.0, 0.2, 50):
        resized_w = int(original_template.shape[1] * scale)
        resized_h = int(original_template.shape[0] * scale)
        if resized_w < 15 or resized_h < 15: continue
            
        resized_t = cv2.resize(original_template, (resized_w, resized_h))
        
        for angle in [0, 90, 180, 270]:
            if angle == 0:   curr_t = resized_t
            elif angle == 90:  curr_t = cv2.rotate(resized_t, cv2.ROTATE_90_CLOCKWISE)
            elif angle == 180: curr_t = cv2.rotate(resized_t, cv2.ROTATE_180)
            elif angle == 270: curr_t = cv2.rotate(resized_t, cv2.ROTATE_90_COUNTERCLOCKWISE)
            
            res = cv2.matchTemplate(search_image, curr_t, cv2.TM_CCOEFF_NORMED)
            
            # This finds ALL pixels that are above the threshold
            loc = np.where(res >= detection_threshold)
            
            h, w = curr_t.shape
            for pt in zip(*loc[::-1]):
                # Add every match found at every scale/angle
                all_found_rects.append([int(pt[0]), int(pt[1]), int(w), int(h)])

# 3. GROUPING
# eps=0.5 allows for slightly more distance between matches before merging
# groupThreshold=1 means a box must be found at least twice to be kept (filters out noise)
rects, weights = cv2.groupRectangles(all_found_rects, groupThreshold=1, eps=0.5)

# 4. DRAW
result_img = img_bgr.copy()
for (x, y, w, h) in rects:
    cv2.rectangle(result_img, (x, y), (x + w, y + h), (0, 255, 0), 3)
    cv2.putText(result_img, "Crown", (x, y - 10), cv2.FONT_HERSHEY_SIMPLEX, 0.6, (0, 255, 0), 2)

print(f"Success! Found {len(rects)} crowns.")

cv2.namedWindow("Result", cv2.WINDOW_NORMAL)
cv2.imshow("Result", result_img)
cv2.waitKey(0)